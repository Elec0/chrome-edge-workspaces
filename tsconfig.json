{
  "compilerOptions": {
      "strict": true,
      "target": "ES2022",
      "esModuleInterop": true,
      "rootDir": "src",
      "allowJs": true,
      "outDir": "build",
      "noEmitOnError": true,
      "typeRoots": [ "node_modules/@types" ],
      "types": ["chrome", "node"],
      "sourceMap": true,
  },
  "include": [
      "src/**/*"
  ],
  "exclude": [
      "src/test/**/*"
  ]
}

